{
  "extends": "../../tsconfig.base.json",
  "include": [
    "src/**/*.js",
    "src/**/*.mjs",
    "src/**/*.cjs",
    "src/**/*.jsx",
    "src/**/*.ts",
    "src/**/*.mts",
    "src/**/*.cts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "src/**/*.test.js",
    "src/**/*.test.ts",
    "src/tests/**/*.js",
    "src/tests/**/*.ts",
    "**/fixtures/**"
  ],
  "compilerOptions": {
    /* Modules */
    "rootDir": "./src",
    "types": [],

    /* Emit */
    "outDir": "build",

    /* Completeness */
    "skipLibCheck": true
  }
}
