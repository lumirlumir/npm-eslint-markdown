{
  "private": true,
  "name": "npm-eslint-markdown",
  "version": "0.9.1",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^20.19.0 || ^22.13.0 || >=24.0.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11.12.1",
      "onFail": "error"
    }
  },
  "workspaces": [
    ".",
    "packages/*",
    "website"
  ],
  "scripts": {
    "prepare": "husky",
    "release:publish": "node -e \"require('child_process').execSync('npm publish -w packages ' + (require('./package.json').version.includes('-') ? '--tag next' : ''), { stdio: 'inherit' })\"",
    "release:version": "node ./scripts/version.js",
    "coverage": "c8 --reporter=lcov npm run test",
    "test": "npm run test -w packages/eslint-markdown",
    "build": "npm-run-all -c -l -p --aggregate-output build:**",
    "build:pkg:em": "npm run build -w packages/eslint-markdown",
    "build:website": "npm run build -w website",
    "dev": "npm run dev:website",
    "dev:website": "npm run dev -w website",
    "start": "npm run start:website",
    "start:website": "npm run start -w website",
    "fix": "npm-run-all -c -l -p fix:*",
    "fix:eslint": "eslint --fix --cache --cache-strategy content",
    "fix:prettier": "prettier . --write --ignore-unknown",
    "fix:markdownlint": "markdownlint **/*.md --fix",
    "lint": "npm-run-all -c -l -p lint:*",
    "lint:eslint": "eslint --cache --cache-strategy content",
    "lint:prettier": "prettier . --check --ignore-unknown",
    "lint:editorconfig": "editorconfig-checker -config .editorconfig-checker.json",
    "lint:markdownlint": "markdownlint **/*.md"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "c8": "^11.0.0",
    "editorconfig-checker": "^6.1.1",
    "eslint": "^9.39.4",
    "eslint-config-bananass": "^0.6.1",
    "eslint-markdown": "^0.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.48.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
